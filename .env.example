# API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Session cookie HMAC key (REQUIRED)
# Must be at least 16 characters. Generate with: openssl rand -base64 32
# Rotating this value invalidates all existing sessions.
SESSION_SECRET=replace_with_openssl_rand_base64_32

# Environment
NODE_ENV=production

# NOTE: Cost limits ($5/hour, $10/day, $15 emergency stop) are hardcoded in
# api/rate-limiter.ts and are NOT configurable via environment variables.

# Admin Access (auth for /api/admin/stats)
ADMIN_TOKEN=your-secure-admin-token-here

# Upstash Redis Configuration (Required for production rate limiting)
# Get these from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Sentry Error Monitoring (Recommended for production)
# Get DSN from: https://sentry.io/
# Create a new project and copy the DSN from Settings > Client Keys
VITE_SENTRY_DSN=https://xxxx@xxx.ingest.sentry.io/xxxx

# Optional: App version for Sentry releases
VITE_APP_VERSION=1.0.0